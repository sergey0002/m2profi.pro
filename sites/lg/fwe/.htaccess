# Показывать ВСЕ PHP-ошибки в браузере
php_flag display_errors On
php_flag display_startup_errors On
php_value error_reporting 1

# Если используете PHP-FPM (некоторые хостинги), вместо флагов используйте:
# php_value display_errors On
# php_value display_startup_errors On
# php_value error_reporting -1

# Настройки для mod_rewrite (если вдруг нужны ЧПУ)
# RewriteEngine On
# RewriteBase /

# Разрешить доступ к скрытым файлам, если нужно (обычно не нужно!)
# <FilesMatch "^\.">
#     Order allow,deny
#     Allow from all
# </FilesMatch>