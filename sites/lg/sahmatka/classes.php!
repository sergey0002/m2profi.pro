	// Соединение
	function __construct($c)
	{
		$this->c = $c;	
	}
	
	// получить по ключу
	function get_for_key( $table , $key_filed , $key_value )
	{
		$q = ' SELECT * FROM '.$table .' WHERE `'.$key_filed.'` = "'.$key_value.'" ' ;
		return $this -> get_arr( $q ,1);
	}
	
	
	// обновить строку таблицы
	function update_for_key( $table , $key_filed , $key_value , $data )
	{
		$q = ' UPDATE '.$table .' SET ';
		$i = 0;
		foreach( $data as $k=>$v )
		{
			$i++;
			$q .= '`'.$k.'` = "'.$v.'" ';
			if($i<count($data)){$q.=' , ';}
		}
		$q.=' WHERE `'.$key_filed.'` = "'.$key_value.'" ' ;
		print $q;
 	}
	
	// Удалить строку из таблицы
	function delete_for_key($table,$key_filed,$value )
	{
		
	}
	
	// Вставить строку в таблицу
	function insert( $table , $data)
	{
 
		$q = ' INSERT INTO '.$table .' ( ';
		$i = 0;
		foreach( $data as $k=>$v )
		{
			$i++;
			$q .=' `'.$k.'` ';
			if($i<count($data)){$q.=' , ';}
		}
		$q .=' ) VALUES (';
		
		$i = 0;
		foreach( $data as $k=>$v )
		{
			$i++;
			$q .=' "'.$v.'" ';
			if($i<count($data)){$q.=' , ';}
		}
		$q .=' );';
 
		if( $this -> sql( $q ) )
		{
			return mysqli_insert_id ( $this->c ); // Если все получилось возвращаем последний вставленный ИД
		}
		else
		{
			//print '----------';
			//print $q;
			//print '----------';
			return false;
		}
	}
	
	// получить ассоциативный массив по sql запросу
	function get_arr($sql,$first=false)
	{
		$query = $this->sql( $sql );
		while( $result = mysqli_fetch_assoc($query) ) 
		{
			 $arr[]=$result;
		}
		if($first){	$arr=$arr[0]; }
		return $arr;
	}
	
	
	// Обработка запроса и логирование 
	function sql($sql)
	{
		 $result =  mysqli_query( $this->c , $sql );
		 
		 if( $result )
		 {
			 return  $result;
		 }
		 else{
			 print mysqli_error($this->c);
		 }
	}
	
	
	
	
}
	
	
	
	
	
	
	
	
	
	
	
	
	


