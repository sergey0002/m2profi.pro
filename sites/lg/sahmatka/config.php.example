// Перехват ошибок в том числе фатальных 
register_shutdown_function( "fatal_handler" );
function fatal_handler() {
	ob_flush();ob_flush();ob_flush();
    $errfile = "unknown file";
    $errstr  = "shutdown";
    $errno   = E_CORE_ERROR;
    $errline = 0;

    $error = error_get_last();

			//print '<pre>';
			//print_r( $error );
			//print '</pre>';
    if($error !== NULL) {
        $errno   = $error["type"];
        $errfile = $error["file"];
        $errline = $error["line"];
        $errstr  = $error["message"];
		if(isset($_GET['dev']))
		{
			
			print '<pre>';
			print_r( $error );
			print '</pre>';
		 
		 
		}
    }
}
