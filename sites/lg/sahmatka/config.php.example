	///Сборка формы для отправки
	function form_message( $data_arr='' , $mess_conf='' , $dev=0 )
	{
		$mess='';
		foreach( $data_arr as $k=>$v)
		{
			if( $mess_conf[$k] )
			{
				$mess.='<b>'.$mess_conf[$k].':</b> '. $data_arr[$k]."\r\n<br/><br/>";
			}
			elseif( $dev )
			{
				$dev_mess.='<b>$mess_conf[\''.$k.'\']</b>="'.$data_arr[$k].'";<br/>';
			}
			else
			{
				
			}
		}
		if($dev){$mess.=$dev_mess;}
		return $mess;
	}
 

