function fromsql_date($mysqldate,$notime=0)
{
	$phpdate = strtotime( $mysqldate );
	if($notime)
	{
		return $normaldate = date( 'd.m.Y', $phpdate );
	}
	else
	{
		return $normaldate = date( 'd.m.Y H:i:s', $phpdate );
	}
}
/* 
 * Custom PHP function to send an email with multiple attachments 
 * $to Recipient email address 
 * $subject Subject of the email 
 * $message Mail body content 
 * $senderEmail Sender email address 
 * $senderName Sender name 
 * $files Files to attach with the email 
 */ 
function multi_attach_mail2($to, $subject, $message, $senderEmail, $senderName, $files = array())
{ 
    // Sender info  
    $from = $senderName." <".$senderEmail.">";  
    $headers = "From: $from"; 
 
    // Boundary  
    $semi_rand = md5(time());  
    $mime_boundary = "==Multipart_Boundary_x{$semi_rand}x";  
 
    // Headers for attachment  
    $headers .= "\nMIME-Version: 1.0\n" . "Content-Type: multipart/mixed;\n" . " boundary=\"{$mime_boundary}\"";  
 
    // Multipart boundary  
    $message = "--{$mime_boundary}\n" . "Content-Type: text/html; charset=\"UTF-8\"\n" . 
    "Content-Transfer-Encoding: 7bit\n\n" . $message . "\n\n";  
 
    // Preparing attachment 
    if(!empty($files)){ 
        for($i=0;$i<count($files);$i++){ 
            if(is_file($files[$i])){ 
                $file_name = basename($files[$i]); 
                $file_size = filesize($files[$i]); 
                 
                $message .= "--{$mime_boundary}\n"; 
                $fp =    @fopen($files[$i], "rb"); 
                $data =  @fread($fp, $file_size); 
                @fclose($fp); 
                $data = chunk_split(base64_encode($data)); 
                $message .= "Content-Type: application/octet-stream; name=\"".$file_name."\"\n" .  
                "Content-Description: ".$file_name."\n" . 
                "Content-Disposition: attachment;\n" . " filename=\"".$file_name."\"; size=".$file_size.";\n" .  
                "Content-Transfer-Encoding: base64\n\n" . $data . "\n\n"; 
            } 
        } 
    } 
     
    $message .= "--{$mime_boundary}--"; 
    $returnpath = "-f" . $senderEmail; 
     
    // Send email 
    $mail = mail($to, $subject, $message, $headers, $returnpath);  
     
    // Return true if email sent, otherwise return false 
    if($mail){ 
        return true; 
    }else{ 
        return false; 
    } 
}
















	function multi_attach_mail($to, $subject, $message, $senderEmail = 'test@m2profi.pro', $senderName = $GLOBALS['config']['domain'], $files = array(), $smtpConfig = []) {
		// Настройки SMTP
		if (empty($smtpConfig)) {
			$smtpConfig = [
				'host' => 'smtp.masterhost.ru', // SMTP-сервер
				'port' => 25,                  // Порт для незащищенного соединения
				'username' => 'test@m2profi.pro', // Ваш email
				'password' => 'zdctvjue123',   // Ваш пароль
			];
		}

		$smtpHost = isset($smtpConfig['host']) ? $smtpConfig['host'] : '';
		$smtpPort = isset($smtpConfig['port']) ? $smtpConfig['port'] : 25; // Порт для незащищенного соединения
		$smtpUsername = isset($smtpConfig['username']) ? $smtpConfig['username'] : '';
		$smtpPassword = isset($smtpConfig['password']) ? $smtpConfig['password'] : '';
		$senderEmail = $smtpConfig['username'];

		// Увеличение времени выполнения скрипта
		set_time_limit(120);

		// Подключение к SMTP серверу
		$smtpConnect = fsockopen($smtpHost, $smtpPort, $errno, $errstr, 30);
		if (!$smtpConnect) {
			print "Не удалось подключиться к SMTP серверу: $errstr ($errno)\n";
			return false;
		}

		// Чтение приветственного сообщения от сервера
		$response = fgets($smtpConnect, 512);
		if (substr($response, 0, 3) != '220') {
			fclose($smtpConnect);
			print "Неверный ответ на приветствие: $response\n";
			return false;
		}

		// HELO
		if (!smtp_msg($smtpConnect, "HELO " . $_SERVER['SERVER_NAME'])) {
			fclose($smtpConnect);
			return false;
		}

		// AUTH LOGIN
		if (!smtp_msg($smtpConnect, "AUTH LOGIN")) {
			fclose($smtpConnect);
			return false;
		}
		if (!smtp_msg($smtpConnect, base64_encode($smtpUsername))) {
			fclose($smtpConnect);
			return false;
		}
		if (!smtp_msg($smtpConnect, base64_encode($smtpPassword))) {
			fclose($smtpConnect);
			return false;
		}

		// MAIL FROM
		if (!smtp_msg($smtpConnect, "MAIL FROM:<" . $senderEmail . ">")) {
			fclose($smtpConnect);
			return false;
		}


		/*
		// RCPT TO
		if (!smtp_msg($smtpConnect, "RCPT TO:<" . $to . ">")) {
			fclose($smtpConnect);
			return false;
		}
		*/
		
		
		


		// RCPT TO для каждого получателя
		$recipients = explode(',', $to);
		foreach ($recipients as $recipient) {
			$recipient = trim($recipient);
			if (!smtp_msg($smtpConnect, "RCPT TO:<" . $recipient . ">")) {
				fclose($smtpConnect);
				return false;
			}
		}
	
	
	

		// DATA
		if (!smtp_msg($smtpConnect, "DATA")) {
			fclose($smtpConnect);
			return false;
		}

		// Генерация заголовков
		$from = $senderName . " <" . $senderEmail . ">";
		$boundary = md5(uniqid(time()));
		$headers = "From: " . $from . "\r\n";
		$headers .= "MIME-Version: 1.0\r\n";
		$headers .= "Content-Type: multipart/mixed; boundary=\"" . $boundary . "\"\r\n";
		$headers .= "Subject: =?UTF-8?B?" . base64_encode($subject) . "?=\r\n"; // Кодировка темы письма в Base64

		// Тело письма
		$body = "--" . $boundary . "\r\n";
		$body .= "Content-Type: text/html; charset=UTF-8\r\n";
		$body .= "Content-Transfer-Encoding: 7bit\r\n\r\n";
		$body .= $message . "\r\n";

		// Вложения
		if (!empty($files)) {
			foreach ($files as $file) {
				if (is_file($file)) {
					$file_name = basename($file);
					$file_size = filesize($file);
					$fp = fopen($file, "rb");
					$data = fread($fp, $file_size);
					fclose($fp);
					$data = chunk_split(base64_encode($data));

					$body .= "--" . $boundary . "\r\n";
					$body .= "Content-Type: application/octet-stream; name=\"" . $file_name . "\"\r\n";
					$body .= "Content-Disposition: attachment; filename=\"" . $file_name . "\"\r\n";
					$body .= "Content-Transfer-Encoding: base64\r\n\r\n";
					$body .= $data . "\r\n";
				}
			}
		}

		$body .= "--" . $boundary . "--\r\n";

		// Отправка письма
		if (!smtp_msg($smtpConnect, $headers . "\r\n" . $body . ".\r\n")) {
			fclose($smtpConnect);
			return false;
		}

		// Завершение соединения
		smtp_msg($smtpConnect, "QUIT");
		fclose($smtpConnect);

		return true;
	}

	// Функция для отправки команд и получения ответов от SMTP-сервера
	function smtp_msg($sock, $msg) {
		if (!$sock) {
			printf("Broken socket!\n");
			exit(1);
		}

		// Отправляем команду
		fputs($sock, "$msg\r\n");

		// Читаем ответ сервера
		$response = '';
		while (($line = fgets($sock, 512)) !== false) {
			$response .= $line;
			// Если строка начинается с цифры и заканчивается пробелом, это последняя строка ответа
			if (preg_match('/^[0-9]{3} /', $line)) {
				break;
			}
		}

		// Разбираем код ответа
		$code = substr($response, 0, 3);
		if ($code >= 400) { // Ошибка, если код больше или равен 400
			//printf("Ошибка SMTP: Code %d. Message: %s\n", $code, trim(substr($response, 4)));
			return false;
		}

		return true;
	}

