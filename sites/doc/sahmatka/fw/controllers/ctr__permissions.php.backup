<?
class ctr__permissions extends ctr__
{
    var $table = 'users_group_permissions'; 
    var $ctr = 'permissions';
    var $title = 'Права доступа';

    function __construct()
    {
        // Only admin access
        if ($_SESSION['sh_login'] != 'admin' && $_SESSION['sh_login'] != 'goodzem') {
            die('Доступ запрещен');
        }
    }

    function act__index()
    {
        global $mysql;
        $t['h1'] = 'Управление правами групп';
        
        $groups = $mysql->get_arr("SELECT * FROM users_group WHERE del=0");
        
        ?>
        <div class="row">
            <div class="col-md-12">
                <h3>Выберите группу для настройки прав</h3>
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Название группы</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        <? foreach($groups as $g): ?>
                        <tr>
                            <td><?=$g['users_group_id']?></td>
                            <td><?=$g['caption']?> (<?=$g['group_name']?>)</td>
                            <td>
                                <a href="?ctr=permissions&act=edit&id=<?=$g['users_group_id']?>" class="btn btn-primary btn-sm">Настроить права</a>
                            </td>
                        </tr>
                        <? endforeach; ?>
                    </tbody>
                </table>
            </div>
        </div>
        <?
    }

    function act__edit()
    {
        global $mysql;
        $group_id = (int)$_GET['id'];
        if (!$group_id) die('Group ID required');

        $group = $mysql->get_for_key('users_group', 'users_group_id', $group_id);
        
        // 0. Fetch all groups for switcher
        $all_groups = $mysql->get_arr("SELECT users_group_id, caption FROM users_group WHERE del=0");

        // 1. Scan Controllers
        $controllers = [];
        $files = glob(__DIR__ . '/ctr__*.php');
        
        foreach ($files as $file) {
            $content = file_get_contents($file);
            $ctr_name = str_replace('.php', '', basename($file));
            
            // Find actions
            preg_match_all('/function\s+act__([a-zA-Z0-9_]+)/', $content, $matches);
            if (!empty($matches[1])) {
                $controllers[$ctr_name] = $matches[1];
            }
        }
        
        // Filter Controllers if requested
        $filter_ctr = isset($_GET['filter_ctr']) ? $_GET['filter_ctr'] : '';

        // 2. Load existing permissions for THIS group (for checkboxes)
        $existing_rules = [];
        $rows = $mysql->get_arr("SELECT rule, access FROM users_group_rules WHERE users_group_id = $group_id");
        foreach ($rows as $row) {
            $existing_rules[$row['rule']] = $row['access'];
        }

        // 3. Discover ALL known rules from DB (to show custom actions added to ANY group)
        $all_rules = $mysql->get_arr("SELECT DISTINCT rule FROM users_group_rules");
        foreach ($all_rules as $row) {
            $rule = $row['rule'];
            if (strpos($rule, '/') !== false && strpos($rule, '/*') === false) {
                list($r_ctr, $r_act) = explode('/', $rule, 2);
                // Find matching controller (with or without ctr__ prefix)
                foreach ($controllers as $ctr_key => $actions) {
                    $ctr_clean = str_replace('ctr__', '', $ctr_key);
                    if ($r_ctr === $ctr_clean) {
                        if (!in_array($r_act, $controllers[$ctr_key])) {
                            $controllers[$ctr_key][] = $r_act;
                        }
                        break;
                    }
                }
            }
        }

        // 4. Get Custom Rules (those not in controllers)
        $custom_rules = [];
        foreach ($all_rules as $row) {
            $rule = $row['rule'];
            if (strpos($rule, '/*') !== false) continue; // Skip wildcards
            
            $is_system = false;
            foreach ($controllers as $ctr => $actions) {
                $ctr_clean = str_replace('ctr__', '', $ctr);
                if (strpos($rule, $ctr_clean . '/') === 0) {
                    $is_system = true; 
                    break;
                }
            }
            if (!$is_system) {
                $access = isset($existing_rules[$rule]) ? $existing_rules[$rule] : 0;
                $custom_rules[$rule] = $access;
            }
        }

        // Prepare Display Controllers (Apply Filter)
        $display_controllers = $controllers;
        if ($filter_ctr) {
            $display_controllers = array_intersect_key($controllers, array_flip([$filter_ctr]));
        }

        ?>
        <style>
            .ctr-block { border: 1px solid #ddd; padding: 15px; margin-bottom: 20px; border-radius: 5px; }
            .ctr-header { background: #f5f5f5; padding: 10px; margin: -15px -15px 15px -15px; border-bottom: 1px solid #ddd; font-weight: bold; }
            .act-item { margin-bottom: 5px; }
            .custom-rule-item { margin-bottom: 10px; border-bottom: 1px solid #eee; padding-bottom: 5px; }
        </style>

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Права доступа</h2>
            <form class="form-inline" method="GET" action="">
                <input type="hidden" name="ctr" value="permissions">
                <input type="hidden" name="act" value="edit">
                
                <select name="id" class="form-control mr-2" onchange="this.form.submit()">
                    <? foreach ($all_groups as $g): ?>
                        <option value="<?=$g['users_group_id']?>" <?=$g['users_group_id'] == $group_id ? 'selected' : ''?>>
                            <?=$g['caption']?>
                        </option>
                    <? endforeach; ?>
                </select>

                <select name="filter_ctr" class="form-control mr-2" onchange="this.form.submit()">
                    <option value="">Все контроллеры</option>
                    <? foreach (array_keys($controllers) as $c_name): ?>
                        <option value="<?=$c_name?>" <?=$c_name == $filter_ctr ? 'selected' : ''?>>
                            <?=$c_name?>
                        </option>
                    <? endforeach; ?>
                </select>
            </form>
        </div>
        
        <form action="?ctr=permissions&act=save" method="POST">
            <input type="hidden" name="group_id" value="<?=$group_id?>">
            
            <div class="row">
                <div class="col-md-12 mb-3">
                    <input type="text" id="rule-search" class="form-control" placeholder="Поиск правила (JS фильтр)...">
                </div>
            </div>

            <div id="controllers-container">
                <? foreach ($display_controllers as $ctr => $actions): ?>
                    <div class="ctr-block" data-ctr="<?=$ctr?>">
                        <div class="ctr-header">
                            <span><?=$ctr?></span>
                        </div>
                        <div class="row">
                            <? foreach ($actions as $act): ?>
                                <? 
                                    // Build clean rule for checking
                                    $ctr_clean = str_replace('ctr__', '', $ctr);
                                    $rule_clean = $ctr_clean . '/' . $act;
                                    $is_allowed = isset($existing_rules[$rule_clean]) && $existing_rules[$rule_clean] == 1;
                                    $checked = $is_allowed ? 'checked' : '';
                                    
                                    // For form submission, use the original format
                                    $rule = $ctr . '/act__' . $act;
                                ?>
                                <div class="col-md-4 act-item">
                                    <label>
                                        <input type="checkbox" class="act-checkbox" data-ctr="<?=$ctr?>" name="permissions[<?=$rule?>]" value="1" <?=$checked?>>
                                        <?=$act?>
                                    </label>
                                </div>
                            <? endforeach; ?>
                        </div>
                        <div class="row mt-2">
                            <div class="col-md-12">
                                <div class="input-group input-group-sm" style="max-width: 300px;">
                                    <input type="text" name="new_ctr_action[<?=$ctr?>]" class="form-control" placeholder="Добавить действие (например, custom_act)">
                                    <div class="input-group-append">
                                        <button class="btn btn-outline-secondary" type="submit">Добавить</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <? endforeach; ?>
            </div>

            <h3>Именованные правила (Custom Rules)</h3>
            <div id="custom-rules-container">
                <? foreach ($custom_rules as $rule => $access): ?>
                    <div class="custom-rule-item">
                        <label>
                            <input type="checkbox" name="permissions[<?=$rule?>]" value="1" <?=$access ? 'checked' : ''?>>
                            <?=$rule?>
                        </label>
                    </div>
                <? endforeach; ?>
            </div>
            
            <div class="card bg-light mb-3">
                <div class="card-body">
                    <h5>Добавить правило</h5>
                    <div class="input-group">
                        <input type="text" name="new_rule_name" class="form-control" placeholder="Название правила (например, delete_docs)">
                        <div class="input-group-append">
                            <span class="input-group-text">
                                <input type="checkbox" name="new_rule_access" value="1" checked> Разрешить
                            </span>
                        </div>
                    </div>
                    <small class="text-muted">Правило будет добавлено при сохранении</small>
                </div>
            </div>

            <button type="submit" class="btn btn-success btn-lg">Сохранить изменения</button>
            <a href="?ctr=permissions&act=index" class="btn btn-secondary">Отмена</a>
        </form>

        <script>
        $(document).ready(function() {
            // Search
            $('#rule-search').on('keyup', function() {
                var value = $(this).val().toLowerCase();
                $('.act-item').filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
                $('.ctr-block').each(function() {
                    if ($(this).find('.act-item:visible').length === 0 && value !== '') {
                        $(this).hide();
                    } else {
                        $(this).show();
                    }
                });
            });
        });
        </script>
        <?
    }

    function act__save()
    {
        global $mysql, $connection;
        
        $group_id = isset($_POST['group_id']) ? (int)$_POST['group_id'] : 0;
        if (!$group_id) {
            die('Group ID required');
        }

        // 1. Clear existing rules for this group
        $connection->query("DELETE FROM users_group_rules WHERE users_group_id = $group_id");

        // 2. Insert new permissions
        if (isset($_POST['permissions']) && is_array($_POST['permissions'])) {
            foreach ($_POST['permissions'] as $rule => $access) {
                $access = (int)$access;
                
                // Parse and clean the rule
                $ctr_clean = null;
                $act_clean = null;
                $rule_clean = $rule;
                
                if (strpos($rule, '/') !== false) {
                    list($ctr_part, $act_part) = explode('/', $rule, 2);
                    $ctr_clean = str_replace('ctr__', '', $ctr_part);
                    if ($act_part !== '*') {
                        $act_clean = str_replace('act__', '', $act_part);
                        $rule_clean = $ctr_clean . '/' . $act_clean;
                    } else {
                        $rule_clean = $ctr_clean . '/*';
                    }
                } elseif (strpos($rule, 'ctr__') === 0) {
                    $ctr_clean = str_replace('ctr__', '', str_replace('/*', '', $rule));
                    $rule_clean = $ctr_clean . '/*';
                }
                
                $ctr_sql = $ctr_clean ? "'" . $connection->real_escape_string($ctr_clean) . "'" : 'NULL';
                $act_sql = $act_clean ? "'" . $connection->real_escape_string($act_clean) . "'" : 'NULL';
                $rule_escaped = $connection->real_escape_string($rule_clean);
                
                $connection->query("INSERT INTO users_group_rules (users_group_id, ctr, act, rule, access) VALUES ($group_id, $ctr_sql, $act_sql, '$rule_escaped', $access)");
            }
        }

        // 3. Add new custom rule (Global)
        if (!empty($_POST['new_rule_name'])) {
            $new_rule = $connection->real_escape_string(trim($_POST['new_rule_name']));
            $new_access = isset($_POST['new_rule_access']) ? 1 : 0;
            if (!isset($_POST['permissions'][$new_rule])) {
                 $connection->query("INSERT INTO users_group_rules (users_group_id, ctr, act, rule, access) VALUES ($group_id, NULL, NULL, '$new_rule', $new_access)");
            }
        }

        // 4. Add new custom controller action
        if (!empty($_POST['new_ctr_action']) && is_array($_POST['new_ctr_action'])) {
            foreach ($_POST['new_ctr_action'] as $ctr => $act_name) {
                if (!empty($act_name)) {
                    $act_name = trim($act_name);
                    
                    // Extract clean names
                    $ctr_clean = str_replace('ctr__', '', $ctr);
                    $act_clean = $act_name;
                    
                    // Build clean rule
                    $rule_clean = $ctr_clean . '/' . $act_clean;
                    
                    $connection->query("INSERT INTO users_group_rules (users_group_id, ctr, act, rule, access) VALUES ($group_id, '$ctr_clean', '$act_clean', '$rule_clean', 1)");
                }
            }
        }

        echo '<script>alert("Права успешно сохранены"); location.href="?ctr=permissions&act=edit&id='.$group_id.'";</script>';
    }
}
?>
