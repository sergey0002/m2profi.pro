# Включить отображение ошибок PHP
php_flag display_errors on
php_flag display_startup_errors on

# Установить уровень отчетности об ошибках на E_ALL (все ошибки)
# php_value error_reporting 32767
# Или более явно:
php_value error_reporting -1

# (Опционально) Включить логирование ошибок (убедитесь, что путь корректен и файл доступен для записи)
# php_flag log_errors on
# php_value error_log /path/to/your/php_errors.log

# Настройки для mod_rewrite (если вдруг нужны ЧПУ)
 

# Отключаем обработку правил из корневого .htaccess
RewriteEngine Off

 
# Разрешаем доступ к файлам в этой папке без редиректов
DirectoryIndex index.php
 

# Разрешить доступ к скрытым файлам, если нужно (обычно не нужно!)
# <FilesMatch "^\.">
#     Order allow,deny
#     Allow from all
# </FilesMatch>