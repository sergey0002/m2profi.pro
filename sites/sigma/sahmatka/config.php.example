if (!function_exists('unit_room_type')) {
	function unit_room_type($rooms) {
		$u = unit_label('pl_nom');
		if (($GLOBALS['config']['object_unit']['mode'] ?? '') === 'custom') {
			return $rooms . '-комн. ' . $u;
		}
		$names = [1 => 'Однокомнатная', 2 => 'Двухкомнатная', 3 => 'Трехкомнатная', 4 => 'Четырехкомнатная'];
		$adj = isset($names[$rooms]) ? $names[$rooms] : ($rooms . '-комнатная');
		return $adj . ' ' . unit_label('nom');
	}
}

