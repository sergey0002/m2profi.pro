if (!function_exists('unit_cfg')) {
	function unit_cfg() {
		return isset($GLOBALS['config']['object_unit']) ? $GLOBALS['config']['object_unit'] : ['mode' => 'legacy'];
	}
}
if (!function_exists('unit_label')) {
	function unit_label($case = 'nom') {
		$cfg = unit_cfg();
		if (($cfg['mode'] ?? '') === 'custom') {
			$forms = isset($cfg['forms']) ? $cfg['forms'] : [];
			if (isset($forms[$case])) {
				return $forms[$case];
			}
			return $cfg['label'] ?? 'резиденции';
		}
		$legacy = isset($cfg['legacy']) ? $cfg['legacy'] : [];
		return isset($legacy[$case]) ? $legacy[$case] : (isset($legacy['nom']) ? $legacy['nom'] : 'квартира');
	}
}
if (!function_exists('unit_label_cap')) {
	function unit_label_cap($case = 'nom') {
		$s = unit_label($case);
		return mb_strtoupper(mb_substr($s, 0, 1)) . mb_substr($s, 1);
	}
}
if (!function_exists('unit_abbrev')) {
	function unit_abbrev() {
		$cfg = unit_cfg();
		if (($cfg['mode'] ?? '') === 'custom') {
			return $cfg['abbrev'] ?? 'рез.';
		}
		return isset($cfg['legacy']['abbrev']) ? $cfg['legacy']['abbrev'] : 'кв.';
	}
}
if (!function_exists('unit_num')) {
	function unit_num($num, $style = 'dot') {
		$abbr = unit_abbrev();
		$num = (string) $num;
		if ($style === 'dash') {
			return rtrim($abbr, '.') . '-' . $num;
		}
		if ($style === 'hash') {
			return $abbr . '№' . $num;
		}
		if ($style === 'colon') {
			return rtrim($abbr, '.') . ':' . $num;
		}
		return $abbr . ' ' . $num;
	}
}
if (!function_exists('unit_rate_abbrev')) {
	function unit_rate_abbrev() {
		return rtrim(unit_abbrev(), '.') . '/мес';
	}
}
if (!function_exists('unit_count_label')) {
	function unit_count_label($count) {
		$cfg = unit_cfg();
		$cf = isset($cfg['count_forms']) ? $cfg['count_forms'] : [];
		$n = abs((int)$count) % 100;
		$n1 = $n % 10;
		if ($n > 10 && $n < 20) {
			return isset($cf['many']) ? $cf['many'] : unit_label('pl_gen');
		}
		if ($n1 > 1 && $n1 < 5) {
			return isset($cf['few']) ? $cf['few'] : unit_label('pl_nom');
		}
		if ($n1 === 1) {
			return isset($cf['one']) ? $cf['one'] : unit_label('nom');
		}
		return isset($cf['many']) ? $cf['many'] : unit_label('pl_gen');
	}
}
if (!function_exists('unit_badge')) {
	function unit_badge() {
		$cfg = unit_cfg();
		if (!empty($cfg['badge_upper'])) {
			return $cfg['badge_upper'];
		}
		return mb_strtoupper(unit_label('nom'));
	}
}
if (!function_exists('unit_template')) {
	function unit_template($key) {
		$cfg = unit_cfg();
		$tpl = isset($cfg['phrase_templates'][$key]) ? $cfg['phrase_templates'][$key] : '';
		if ($tpl === '') {
			return $key;
		}
		$repl = [
			'{nom}' => unit_label('nom'),
			'{gen}' => unit_label('gen'),
			'{dat}' => unit_label('dat'),
			'{acc}' => unit_label('acc'),
			'{pl_nom}' => unit_label('pl_nom'),
			'{pl_gen}' => unit_label('pl_gen'),
			'{nom_cap}' => unit_label_cap('nom'),
			'{pl_nom_cap}' => unit_label_cap('pl_nom'),
			'{pl_gen_cap}' => unit_label_cap('pl_gen'),
		];
		return strtr($tpl, $repl);
	}
}
if (!function_exists('unit_js_export')) {
	function unit_js_export() {
		return [
			'nom' => unit_label('nom'),
			'nomCap' => unit_label_cap('nom'),
			'acc' => unit_label('acc'),
			'pl_nom' => unit_label('pl_nom'),
			'pl_nomCap' => unit_label_cap('pl_nom'),
			'pl_gen' => unit_label('pl_gen'),
			'abbrev' => unit_abbrev(),
			'compred_delete_confirm' => unit_phrase('compred_delete_confirm'),
		];
	}
}
