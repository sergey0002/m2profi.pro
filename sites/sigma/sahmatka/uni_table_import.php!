			 $data[$fv] = $v[$fk];
		}
					
		// print_R($this->fa_key)	;
		// Поиск данных по ключевым полям
		foreach($this->fa_key as $k=>$v)
		{
			// ФОрмируем массив ключ=значение
			$key_arr[$k]=$data[$k];
		}
		
		// Массив старой информации по ключам
		$old_data = $this->get_for_keys($key_arr);
		
		//print 'Новые данные ';
		//print '<pre>';
		//print_r($data);
		//print '</pre>'; 
			
		if($old_data)
		{
			//print 'старые данные:';
			
			//print '<pre>';
			//print_r($old_data);
			//print '</pre>';
	 
			// Ставниваем старую и новую информацию
			$ravno=1;
			foreach($data as $k=>$v)
			{
				
				 $res[$k]['old']=$old_data[$k];
				 $res[$k]['new']=$data[$k];
				 
				 if($this->fa_key[$k])
				 {
				 $res[$k]['key']=1;
				 }
				 else{
					  $res[$k]['key']=0;
				 }
				 
				if( $data[$k]!= $old_data[$k] )
				{
					$ravno=0;
					$res[$k]['rav']=0;
					$res[$k]['txt']=' поле - '.$k.' Данные <b><u>НЕ совпадают</u></b> '.$data[$k].' != '.$old_data[$k].'<br/>'; 
				}
				else{ $res[$k]['rav']=1;   $res[$k]['txt']='поле - '.$k.' Данные <b>cовпадают</b> '.$data[$k].' = '.$old_data[$k].'<br/>';}
			}
			
			if(!$ravno)
			{
				print '<h2>UPDATE '.$this->mainkey.'="'.$old_data[$this->mainkey].'"</h2>';
			}
			 
		}
		else
		{
			$ravno=2;
			//print '<b>Данные не найдены - новая строка</b>';
			
			print '<h2>insert</h2>';
			// $this->mysql->insert('rent_objects',$data);
			
		}
		
		// Поля по умолчанию + вычисляемые
		$data=$this->default_data($data);
 
		$x = ob_get_clean();
		$result=array();
		$result['tr']=$ravno; // 1 все совпадают,0- не совпадают, 2- не найдены
		$result['td']=$res;
		$result['trtext']=$x;
		 
		return $result;
	}
	
	
				
				
