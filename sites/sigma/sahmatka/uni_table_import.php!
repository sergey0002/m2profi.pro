	 {
		 
		 $q='SELECT * FROM rent_objects WHERE 1=1 ';
		 foreach ($keys as $k=>$v )
		 {
			 $q.=' AND '.$k.'="'.$v.'" ' ;
		 }
		 print '<br/>'.$q.'<br/>';
		 $arr =  $this->mysql->get_arr($q);
		 
		 //Пишем первичный ключ в масив 
		 $this->update_keys[]=$arr[0][$this->mainkey];
		 
		 if(count($arr)>1)
