RewriteEngine On
RewriteBase /

# Исключение для отдельной панели (sites/panel/) - прямой доступ
RewriteRule ^sites/panel/ - [L]


# HTTPS редирект
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# ============================================================
# БЕЗОПАСНОСТЬ: ЗАПРЕТ ПРЯМОГО ДОСТУПА К /sites/
# ============================================================
# Блокируем любые попытки прямого доступа к /sites/
# Используем %{THE_REQUEST} чтобы отловить только оригинальные запросы браузера
# Внутренние rewrite не попадут под это правило
RewriteCond %{THE_REQUEST} \s/sites/ [NC]
RewriteRule ^sites/ - [F,L]

# Также блокируем прямой доступ к /laracore/
RewriteCond %{THE_REQUEST} \s/laracore/ [NC]
RewriteRule ^laracore/ - [F,L]

# ============================================================
# PANEL: Полностью в Laravel (Filament Admin)
# ============================================================
RewriteCond %{HTTP_HOST} ^panel\.m2profi\.pro\.test$ [NC]
RewriteRule ^(.*)$ sites/panel/public/$1 [L,QSA]

# ============================================================
# MINE: Полностью в Laravel (Filament Platform)
# ============================================================
RewriteCond %{HTTP_HOST} ^mine\.m2profi\.pro\.test$ [NC]
RewriteCond %{REQUEST_URI} !^/laracore/public/
RewriteRule ^(.*)$ laracore/public/$1 [L,QSA]

# ============================================================
# EM и другие клиенты: /la/ в Laravel, остальное в legacy
# ============================================================

# Debugbar для всех
RewriteRule ^_debugbar/(.*)$ laracore/public/_debugbar/$1 [L,QSA]

# Shared Laravel Assets (themes, build, vendor, etc.)
RewriteCond %{HTTP_HOST} ^([a-z0-9][-a-z0-9]*)\.m2profi\.pro\.test$ [NC]
RewriteCond %{HTTP_HOST} !^mine\.m2profi\.pro\.test$ [NC]
RewriteCond %{REQUEST_URI} ^/(themes|build|vendor|css|js|images|fonts)/ [NC]
RewriteRule ^(.*)$ laracore/public/$1 [L,QSA]

# Force trailing slash for /la
RewriteCond %{HTTP_HOST} ^([a-z0-9][-a-z0-9]*)\.m2profi\.pro\.test$ [NC]
RewriteCond %{HTTP_HOST} !^mine\.m2profi\.pro\.test$ [NC]
RewriteCond %{REQUEST_URI} ^/la$ [NC]
RewriteRule ^(.*)$ https://%{HTTP_HOST}/la/ [R=301,L]

# /la/ → Laravel
RewriteCond %{HTTP_HOST} ^([a-z0-9][-a-z0-9]*)\.m2profi\.pro\.test$ [NC]
RewriteCond %{HTTP_HOST} !^mine\.m2profi\.pro\.test$ [NC]
RewriteCond %{REQUEST_URI} ^/la/
RewriteCond %{REQUEST_URI} !^/laracore/
RewriteRule ^la/(.*)$ laracore/public/la/$1 [L,QSA]

# Внутренний rewrite для клиентских субдоменов (все кроме /la/)
RewriteCond %{ENV:REDIRECT_SUBDOMAIN} =""
RewriteCond %{HTTP_HOST} ^([a-z0-9][-a-z0-9]*)\.m2profi\.pro\.test$ [NC]
RewriteCond %{HTTP_HOST} !^mine\.m2profi\.pro\.test$ [NC]
RewriteCond %{REQUEST_URI} !^/sites/
RewriteCond %{REQUEST_URI} !^/laracore/
RewriteCond %{REQUEST_URI} !^/la/
RewriteCond %{REQUEST_URI} !^/_debugbar/
RewriteRule ^(.*)$ sites/%1/$1 [E=SUBDOMAIN:%1,L]

<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
</IfModule>